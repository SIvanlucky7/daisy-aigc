# Copy this file to .env, then edit the values before production.
# System environment variables take priority over values in .env.

PORT=9910
# Public frontend domains that may call this backend.
DAISY_ALLOWED_ORIGINS=http://localhost:9910,http://127.0.0.1:9910,https://daisy-aigc.vercel.app
# Public backend URL used by the static frontend when API is hosted separately.
API_BASE_URL=
# Set these to a mounted persistent disk path on cloud hosts.
DAISY_DB_FILE=daisy.db
DAISY_ORDERS_FILE=orders.jsonl
DAISY_DEFAULT_USER_ID=demo-user
DAISY_INITIAL_BALANCE_CENTS=3680
DAISY_REGISTRATION_BONUS_CENTS=0
DAISY_SESSION_TTL_SECONDS=1209600
# Production should keep this enabled so anonymous visitors cannot spend model quota.
DAISY_REQUIRE_AUTH_FOR_BILLABLE=1
# Keep this 0 in production. Setting 1 allows recharge/deduction on ephemeral
# stores such as Vercel /tmp and is only safe for internal smoke tests.
DAISY_ALLOW_EPHEMERAL_BILLING=0
# Vercel/HTTPS should use secure cookies. Leave 0 only for local http:// testing.
DAISY_COOKIE_SECURE=0
# Use None when a static mirror on another domain calls this backend.
DAISY_COOKIE_SAMESITE=Lax

# Billing and payment.
DAISY_PAYMENT_WEBHOOK_SECRET=change-this-payment-secret
# Use mock while testing. For real QR-code collection, use:
# DAISY_PAYMENT_PROVIDER=manual_qr
# DAISY_ENABLE_MOCK_PAYMENT=0
# DAISY_MANUAL_PAYMENT_QR_URL=/pay/alipay.png
DAISY_PAYMENT_PROVIDER=mock
DAISY_ENABLE_MOCK_PAYMENT=1
DAISY_MANUAL_PAYMENT_QR_URL=
DAISY_MANUAL_PAYMENT_ACCOUNT=支付宝收款码
DAISY_MANUAL_PAYMENT_INSTRUCTIONS=扫码支付对应金额，并在付款备注中填写支付单号。付款后提交交易号，等待后台核账入账。

# Upload and stored result retention.
DAISY_MAX_UPLOAD_BYTES=15728640
DAISY_MAX_EXTRACTED_CHARS=6000
# 0 disables automatic result cleanup. Use 30 or 90 in production.
DAISY_RESULT_RETENTION_DAYS=0

# Admin, auth, and API limits.
DAISY_ADMIN_EMAILS=admin@daisy.local
DAISY_ADMIN_PASSWORD=change-this-admin-password
DAISY_API_RATE_LIMIT_PER_HOUR=60
DAISY_LOGIN_MAX_FAILED_ATTEMPTS=8
DAISY_LOGIN_LOCK_SECONDS=900

# Supabase email/password auth. Use the public project URL and anon key only.
# Never place a Supabase service_role key in frontend code or Vercel/Netlify public env.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# BypassAIGC facade. Commercial use requires the author's commercial license
# or your own compatible implementation behind the same API.
BYPASS_BASE_URL=http://localhost:9800/api
BYPASS_ADMIN_USERNAME=admin
BYPASS_ADMIN_PASSWORD=change-me
BYPASS_CARD_PREFIX=DAISY
DAISY_BYPASS_COMMERCIAL_AUTHORIZED=0

# OpenAI-compatible API for duplicate-rate reduction.
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.deepseek.com
REWRITE_MODEL=deepseek-chat

# Keep enabled while testing UI without spending API quota.
# Set to 0 in production so upstream failures are visible.
DAISY_DEMO_FALLBACK=1
