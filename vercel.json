{
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/login/?", "dest": "/login/index.html" },
    { "src": "/register/?", "dest": "/register/index.html" },
    { "src": "/forgot-password/?", "dest": "/forgot-password/index.html" },
    { "src": "/reset-password/?", "dest": "/reset-password/index.html" },
    { "src": "/dashboard/?", "dest": "/dashboard/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
